+        // --- Weight cache: release GGUF mmap pages after NPU upload ---
+        // data points to GGUF mmap (MAP_SHARED, PROT_READ), not to RKNPU buffer.
+        // After mem_sync TO_DEVICE, the NPU has its own DMA copy, so GGUF pages
+        // are no longer needed for this weight tensor.
+        // madvise(MADV_DONTNEED) on MAP_SHARED releases clean pages from page cache.
+        // If the kernel re-faults them later (e.g. from CPU fallback), it re-reads from disk.
+        if (offset == 0 && data != nullptr && size > 0) {
+            uintptr_t ps = sysconf(_SC_PAGESIZE);
+            uintptr_t addr_start = (uintptr_t)data & ~(ps - 1);
+            uintptr_t addr_end = ((uintptr_t)data + size + ps - 1) & ~(ps - 1);
+            size_t aligned_size = addr_end - addr_start;
+            madvise((void*)addr_start, aligned_size, MADV_DONTNEED);
+        }
